{
    "name": "@simplix/dom",
    "version": "0.2.2",
    "description": "Shared DOM event and interaction logic for UI framework adapters built on Simplix behavior contracts.",
    "keywords": [
        "dom",
        "dom-events",
        "event-listener",
        "event-binding",
        "keyboard-events",
        "pointer-events",
        "focus-events",
        "interaction-bindings",
        "framework-adapter",
        "typescript"
    ],
    "license": "Apache-2.0",
    "type": "module",
    "author": {
        "name": "Noctua Constans",
        "url": "https://github.com/noctua-constans"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/noctua-constans/simplix-ui.git"
    },
    "homepage": "https://github.com/noctua-constans/simplix-ui",
    "bugs": {
        "url": "https://github.com/noctua-constans/simplix-ui/issues"
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "sideEffects": false,
    "files": [
        "dist",
        "README.md",
        "LICENSE",
        "NOTICE"
    ],
    "engines": {
        "node": ">=20",
        "pnpm": ">=10"
    },
    "scripts": {
        "build": "tsup",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    },
    "packageManager": "pnpm@10.25.0",
    "dependencies": {
        "@simplix/headless": "workspace:^"
    },
    "devDependencies": {
        "vite-tsconfig-paths": "^6.1.1",
        "vitest": "^4.0.17"
    }
}

{
    "name": "@simplix/contracts",
    "version": "0.1.1",
    "description": "Shared TypeScript contracts for Simplix runtime primitives and integration APIs.",
    "keywords": [
        "contracts",
        "interfaces",
        "types",
        "primitives",
        "lifecycle",
        "observable",
        "subscriptions",
        "runtime",
        "typescript"
    ],
    "license": "Apache-2.0",
    "type": "module",
    "author": {
        "name": "Noctua Constans",
        "url": "https://github.com/noctua-constans"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/noctua-constans/simplix-ui.git"
    },
    "homepage": "https://github.com/noctua-constans/simplix-ui",
    "bugs": {
        "url": "https://github.com/noctua-constans/simplix-ui/issues"
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "sideEffects": false,
    "files": [
        "dist",
        "README.md",
        "LICENSE",
        "NOTICE"
    ],
    "engines": {
        "node": ">=20",
        "pnpm": ">=10"
    },
    "scripts": {
        "build": "tsup",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    },
    "packageManager": "pnpm@10.25.0"
}

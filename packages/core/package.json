{
    "name": "@simplix/core",
    "version": "0.1.0",
    "description": "Low-level engines for state, transitions, and reusable runtime primitives.",
    "keywords": [
        "state-machine",
        "finite-state-machine",
        "state",
        "transitions",
        "transition-table",
        "runtime",
        "primitives",
        "observable",
        "subscriptions",
        "typescript"
    ],
    "license": "Apache-2.0",
    "type": "module",
    "author": {
        "name": "Noctua Constans",
        "url": "https://github.com/noctua-constans"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/noctua-constans/simplix-ui.git"
    },
    "homepage": "https://github.com/noctua-constans/simplix-ui",
    "bugs": {
        "url": "https://github.com/noctua-constans/simplix-ui/issues"
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "sideEffects": false,
    "files": [
        "dist",
        "README.md",
        "LICENSE",
        "NOTICE"
    ],
    "engines": {
        "node": ">=20",
        "pnpm": ">=10"
    },
    "scripts": {
        "build": "tsup",
        "clean": "rm -rf dist",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage --coverage.reporter=text-summary --coverage.reporter=json",
        "test:coverage:text": "vitest run --coverage --coverage.reporter=text",
        "test:coverage:html": "vitest run --coverage --coverage.reporter=html"
    },
    "packageManager": "pnpm@10.25.0",
    "devDependencies": {
        "vite-tsconfig-paths": "^6.1.1",
        "vitest": "^4.0.17"
    }
}

{
    "name": "@simplix/headless",
    "version": "0.1.0",
    "description": "Public behavior contracts and headless logic built on @simplix/core, without DOM or UI assumptions.",
    "keywords": [
        "headless",
        "behavior-contracts",
        "component-behavior",
        "interaction-patterns",
        "control-logic",
        "framework-agnostic",
        "renderless",
        "unstyled",
        "accessibility",
        "typescript"
    ],
    "license": "Apache-2.0",
    "type": "module",
    "author": {
        "name": "Noctua Constans",
        "url": "https://github.com/noctua-constans"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/noctua-constans/simplix-ui.git"
    },
    "homepage": "https://github.com/noctua-constans/simplix-ui",
    "bugs": {
        "url": "https://github.com/noctua-constans/simplix-ui/issues"
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "sideEffects": false,
    "files": [
        "dist",
        "README.md",
        "LICENSE",
        "NOTICE"
    ],
    "dependencies": {
        "@simplix/core": "workspace:^"
    },
    "engines": {
        "node": ">=20",
        "pnpm": ">=10"
    },
    "scripts": {
        "build": "tsup",
        "clean": "rm -rf dist",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage --coverage.reporter=text",
        "typecheck:src": "tsc -p tsconfig.json --noEmit",
        "typecheck:test": "tsc -p test/tsconfig.json --noEmit",
        "typecheck": "pnpm run typecheck:src && pnpm run typecheck:test"
    },
    "packageManager": "pnpm@10.25.0"
}

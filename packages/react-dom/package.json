{
    "name": "@simplix/react-dom",
    "version": "0.1.0",
    "description": "A modular, type-safe foundation for Simplix UI. Headless logic, utilities, and shared primitives for building consistent UI components.",
    "license": "Apache-2.0",
    "type": "module",
    "author": {
        "name": "Noctua Constans",
        "url": "https://github.com/noctua-constans"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/noctua-constans/simplix-ui.git"
    },
    "homepage": "https://github.com/noctua-constans/simplix-ui",
    "bugs": {
        "url": "https://github.com/noctua-constans/simplix-ui/issues"
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "sideEffects": false,
    "files": [
        "dist",
        "README.md",
        "LICENSE",
        "NOTICE"
    ],
    "dependencies": {
        "@simplix/headless": "workspace:^",
        "@simplix/dom": "workspace:^"
    },
    "devDependencies": {
        "react": "^19.2",
        "react-dom": "^19.2",
        "@types/react": "^19.2",
        "@types/react-dom": "^19.2"
    },
    "engines": {
        "node": ">=20",
        "pnpm": ">=10"
    },
    "scripts": {
        "build": "tsup",
        "clean": "rm -rf dist",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage --coverage.reporter=text",
        "typecheck:src": "tsc -p tsconfig.json --noEmit",
        "typecheck": "pnpm run typecheck:src && pnpm run typecheck:test"
    },
    "packageManager": "pnpm@10.25.0"
}
